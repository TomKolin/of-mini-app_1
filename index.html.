<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>OnlyFans Mini</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background: linear-gradient(135deg, #0a0a0a 0%, #1a1a1a 100%);
            color: #fff;
            padding: 20px;
            min-height: 100vh;
        }
        .container { max-width: 500px; margin: 0 auto; }
        h1 {
            color: #ff00aa;
            font-size: 28px;
            text-align: center;
            margin-bottom: 8px;
        }
        .subtitle {
            color: #888;
            font-size: 14px;
            text-align: center;
            margin-bottom: 30px;
        }
        .card {
            background: rgba(26, 26, 26, 0.95);
            padding: 24px;
            border-radius: 20px;
            margin-bottom: 20px;
            border: 1px solid rgba(255, 0, 170, 0.3);
        }
        .benefits li {
            margin-bottom: 14px;
            padding-left: 32px;
            position: relative;
            font-size: 16px;
        }
        .benefits li:before {
            content: "🔥";
            position: absolute;
            left: 0;
        }
        button {
            width: 100%;
            padding: 16px;
            font-size: 17px;
            font-weight: bold;
            border: none;
            border-radius: 12px;
            cursor: pointer;
            margin: 10px 0;
        }
        .pay-btn {
            background: linear-gradient(135deg, #ff8800, #ff5500);
            color: white;
        }
        .support-btn {
            background: transparent;
            border: 1px solid #ff00aa;
            color: #ff00aa;
        }
        .status {
            margin-top: 15px;
            padding: 15px;
            border-radius: 12px;
            text-align: center;
            font-size: 14px;
        }
        .status.success { background: rgba(0, 255, 100, 0.2); color: #00ff88; }
        .status.error { background: rgba(255, 60, 60, 0.2); color: #ff4444; }
        .progress-bar {
            height: 6px;
            background: #333;
            border-radius: 3px;
            margin: 15px 0;
            overflow: hidden;
        }
        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, #ff00aa, #ff8800);
            width: 0%;
            transition: width 0.4s;
        }
    </style>
</head>
<body>
<div class="container">
    <h1>🔥 OnlyFans Mini</h1>
    <div class="subtitle">Exclusive content • Private chats • Live streams</div>

    <div class="card">
        <h2 style="color:#ff00aa; margin-bottom:15px;">What you get after payment</h2>
        <ul class="benefits">
            <li>Full access to 1000+ hot photos and videos</li>
            <li>Private 1-on-1 chats with models</li>
            <li>Live streams and custom content requests</li>
            <li>Weekly fresh updates</li>
            <li>Anonymous payment via TON</li>
            <li>Instant access link in this chat</li>
        </ul>
    </div>

    <button id="payBtn" class="pay-btn">💰 Pay 0.1 TON for FULL ACCESS</button>

    <div id="paymentOptions" style="display:none; gap:10px;">
        <button onclick="openTelegramWallet()">💎 Telegram Wallet</button>
        <button onclick="openExternalWallet()">🔗 TON Keeper / Tonhub</button>
        <button onclick="installWallet()">📲 Install TON Wallet</button>
    </div>

    <div id="status" class="status"></div>
    <div id="progressBar" class="progress-bar" style="display:none;">
        <div id="progressFill" class="progress-fill"></div>
    </div>

    <button onclick="contactSupport()" class="support-btn">💬 Support</button>
</div>

<script>
    const tg = window.Telegram?.WebApp;
    let userId = tg?.initDataUnsafe?.user?.id || 0;

    const BACKEND_URL = "https://tomkolins.pythonanywhere.com/check_payment";
    const walletAddress = "UQA4aInFqReAIe9UrFhqu-CRzhpLAGwAZJKAEYMO_KIjK0ni";

    // Кнопка оплаты
    document.getElementById("payBtn").addEventListener("click", () => {
        if (userId === 0) {
            alert("Please open this mini app from the bot @onlyfansssssss_bot");
            return;
        }
        document.getElementById("paymentOptions").style.display = "flex";
    });

    function showStatus(message, type = "info") {
        const el = document.getElementById("status");
        el.textContent = message;
        el.className = `status ${type}`;
        el.style.display = "block";
    }

    async function checkPayment(comment) {
        let attempt = 1;
        const maxAttempts = 20;

        while (attempt <= maxAttempts) {
            showStatus(`Checking payment... (${attempt}/${maxAttempts})`, "info");

            try {
                const response = await fetch(BACKEND_URL, {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ comment: comment })
                });
                const data = await response.json();

                if (data.paid) {
                    showStatus("✅ Payment confirmed! Access link sent to this chat!", "success");
                    return;
                }
            } catch (e) {
                console.error(e);
            }

            await new Promise(resolve => setTimeout(resolve, 5000));
            attempt++;
        }
        showStatus("❌ Payment not found. Check comment and amount.", "error");
    }

    // Платёжные функции
    function openTelegramWallet() {
        const comment = `onlyfansaccess_${userId}`;
        const text = `Address: ${walletAddress}\nComment: ${comment}\nAmount: 0.1 TON`;
        navigator.clipboard.writeText(text);
        window.open("https://t.me/wallet", "_blank");
        setTimeout(() => checkPayment(comment), 3000);
    }

    function openExternalWallet() {
        const comment = `onlyfansaccess_${userId}`;
        const link = `ton://transfer/${walletAddress}?amount=100000000&text=${encodeURIComponent(comment)}`;
        window.open(link, "_blank");
        setTimeout(() => checkPayment(comment), 3000);
    }

    function installWallet() {
        window.open("https://ton.org/wallets", "_blank");
    }

    function contactSupport() {
        window.open("https://t.me/AntonDrogovoz", "_blank");
    }

    // Приветствие
    if (tg) {
        tg.ready();
        tg.expand();
    }
</script>
</body>
</html>
